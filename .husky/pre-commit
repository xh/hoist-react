yarn run lint-staged

# Only run TypeScript compiler if TS/JS/TSX/JSX files or package files are staged
if git diff --cached --name-only --diff-filter=ACMRD | grep -qE '\.(ts|tsx|js|jsx)$|package\.json$|package-lock\.json$|yarn\.lock$|tsconfig.*\.json$'; then
  yarn run tsc
fi

# Ensure css-data.json stays in sync when SCSS files change
if git diff --cached --name-only --diff-filter=ACMRD | grep -qE '\.scss$'; then
  node bin/generate-css-data.mjs --check
fi
