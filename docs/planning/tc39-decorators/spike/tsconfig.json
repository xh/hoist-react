{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "lib": ["dom", "es2022"],
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": false,
        "noImplicitOverride": true,
        "useDefineForClassFields": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"]
}
